APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ASSET_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=change_me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Em produção (TLS no Traefik) defina como true para enviar o cookie de sessão
# apenas via HTTPS (flag Secure). Em dev local sem TLS, mantenha false/vazio.
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# sync = jobs inline (consultas de CNPJ bloqueiam o request). Produção usa
# QUEUE_CONNECTION=database + container worker (ver camada de consultas abaixo).
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis é opcional; só use se quiser performance extra
REDIS_CLIENT=phpredis
REDIS_HOST=redis
# Em Docker Swarm, se não funcionar com "redis", tente "redis_redis" (formato stack_servicename)
# REDIS_HOST=redis_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SUPPORT_ADDRESS=suporte@fiscaldock.com.br
MAIL_SUPPORT_NAME="Suporte FiscalDock"
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

TRUSTED_PROXIES=*
TRUSTED_HOSTS=hub.meudominio.com

# ============================================
# Webhooks n8n
# Cutover 2026-06-07: o n8n ficou APENAS com a extração de documentos EFD
# (ver "EFD - webhooks de importação" abaixo). Consultas de CNPJ migraram 100%
# para a camada de consultas do Laravel (app/Services/Consultas + fila database).
# Os webhooks de consulta de CNPJ, clearance DF-e e importação XML foram removidos.
# ============================================

# Token para APIs internas (n8n -> Laravel)
API_TOKEN=

# APIs públicas externas
RECEITAWS_API_URL=https://www.receitaws.com.br/v1
VIACEP_API_URL=https://viacep.com.br/ws

# EFD - webhooks de importação (extração completa por tipo) — único uso restante do n8n
WEBHOOK_IMPORTACAO_EFD_CONTRIBUICOES_URL=
WEBHOOK_IMPORTACAO_EFD_FISCAL_URL=

# ============================================
# Camada de consultas (Laravel) — consultas de CNPJ
# Provedor InfoSimples chamado direto pelo Laravel (app/Services/Consultas).
# Requer fila assíncrona: QUEUE_CONNECTION=database + container worker rodando.
# ============================================
INFOSIMPLES_TOKEN=
# Gate de cutover: true roteia os planos pagos pela camada Laravel; false recusa (não há mais n8n).
CONSULTAS_INFOSIMPLES_ATIVO=false
# CNPJs de teste para validação manual (opcional, separados por vírgula)
CONSULTAS_INFOSIMPLES_TESTE_CNPJS=
